{
  "name": "agents-company",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.6",
    "pg": "^8.20.0",
    "playwright-core": "^1.59.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3",
    "vitest": "^3.1.3"
  },
  "scripts": {
    "check:repo": "python3 .github/scripts/repo_guardrails.py",
    "check:replay": "python3 .github/scripts/check_replay_regression.py",
    "dev": "pnpm -r --parallel --filter './apps/*' --filter './server/*' run dev",
    "build": "pnpm -r --filter './packages/*' --filter './server/*' --filter './apps/*' run build",
    "typecheck": "pnpm -r --filter './packages/*' --filter './server/*' --filter './apps/*' run typecheck",
    "lint": "biome check .",
    "test": "vitest run && pnpm --filter @escalonalabs/github-app test",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "smoke:control-plane": "pnpm --filter @escalonalabs/control-plane exec tsx ../../scripts/smoke-control-plane.ts",
    "smoke:control-web": "pnpm --filter @escalonalabs/control-plane exec tsx ../../scripts/smoke-control-web.ts",
    "smoke:github-backbone": "pnpm --filter @escalonalabs/control-plane exec tsx ../../scripts/smoke-github-backbone.ts",
    "smoke:memory": "pnpm --filter @escalonalabs/control-plane exec tsx ../../scripts/smoke-memory.ts",
    "smoke:runtime": "pnpm --filter @escalonalabs/control-plane exec tsx ../../scripts/smoke-runtime.ts",
    "smoke:customer-foundations": "pnpm --filter @escalonalabs/control-plane exec tsx ../../scripts/smoke-customer-foundations.ts",
    "smoke:self-hosted": "pnpm --filter @escalonalabs/control-plane exec tsx ../../scripts/smoke-self-hosted.ts",
    "smoke:bootstrap": "pnpm db:migrate && pnpm db:seed && pnpm smoke:control-plane && pnpm smoke:memory",
    "release:evidence": "pnpm exec tsx scripts/build-release-evidence.ts",
    "ops:backup:postgres": "bash scripts/ops/backup-postgres.sh",
    "ops:restore-drill:postgres": "bash scripts/ops/restore-drill-postgres.sh",
    "ops:drill:compose-recovery": "bash scripts/ops/drill-compose-recovery.sh",
    "ops:validate:helm": "bash scripts/ops/validate-helm.sh",
    "ops:validate:aws-infra": "bash scripts/ops/validate-aws-infra.sh",
    "ops:validate:m15": "pnpm ops:validate:helm && pnpm ops:validate:aws-infra",
    "dev:stack": "docker compose up -d postgres minio mailpit",
    "dev:stack:down": "docker compose down",
    "db:migrate": "pnpm --filter @escalonalabs/control-plane run db:migrate",
    "db:seed": "pnpm --filter @escalonalabs/control-plane run db:seed"
  }
}
