{
  "name": "agents-company",
  "version": "0.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.3",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^3.1.3"
  },
  "scripts": {
    "check:repo": "python3 .github/scripts/repo_guardrails.py",
    "check:replay": "python3 .github/scripts/check_replay_regression.py",
    "dev": "pnpm -r --parallel --filter './apps/*' --filter './server/*' run dev",
    "build": "pnpm -r --filter './packages/*' --filter './server/*' --filter './apps/*' run build",
    "typecheck": "pnpm -r --filter './packages/*' --filter './server/*' --filter './apps/*' run typecheck",
    "lint": "biome check .",
    "test": "vitest run",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "dev:stack": "docker compose up -d postgres minio mailpit",
    "dev:stack:down": "docker compose down",
    "db:migrate": "pnpm --filter @escalonalabs/control-plane run db:migrate",
    "db:seed": "pnpm --filter @escalonalabs/control-plane run db:seed"
  }
}
