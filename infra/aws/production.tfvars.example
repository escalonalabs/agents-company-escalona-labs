environment = "production"

aws_region           = "us-east-1"
kubernetes_namespace = "agents-company-production"

vpc_id             = "vpc-0123456789abcdef0"
vpc_cidr_block     = "10.30.0.0/16"
private_subnet_ids = ["subnet-aaaaaaaaaaaaaaaaa", "subnet-bbbbbbbbbbbbbbbbb"]
public_subnet_ids  = ["subnet-ccccccccccccccccc", "subnet-ddddddddddddddddd"]

eks_public_access_cidrs = ["198.51.100.0/24"]

node_instance_types = ["m6i.large"]
node_desired_size   = 3
node_min_size       = 3
node_max_size       = 6

db_instance_class        = "db.r6g.large"
db_allocated_storage     = 200
db_backup_retention_days = 14
db_multi_az              = true
db_skip_final_snapshot   = false
artifact_bucket_name     = "agents-company-production-artifacts"
service_account_names    = ["agents-company-control-plane", "agents-company-github-app"]

mail_smtp_url       = "smtp://smtp-user:smtp-password@email-smtp.us-east-1.amazonaws.com:587"
mail_from           = "Agents Company <no-reply@agents-company.escalonalabs.com>"
ses_sender_email    = "no-reply@agents-company.escalonalabs.com"
session_secret      = "replace-with-long-random-session-secret"
internal_api_token  = "replace-with-long-random-internal-token"
github_app_id       = "123456"
github_webhook_secret = "replace-with-github-webhook-secret"
github_private_key  = <<EOF
-----BEGIN PRIVATE KEY-----
replace-with-production-github-app-private-key
-----END PRIVATE KEY-----
EOF

tags = {
  Project     = "agents-company"
  Environment = "production"
  ManagedBy   = "terraform"
}
